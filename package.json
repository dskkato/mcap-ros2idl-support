{
  "name": "mcap-schema-cli",
  "version": "0.0.1",
  "main": "dist/index.js",
  "bin": {
    "mcap-schema-cli": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "test": "tsc && npm run build && node --test dist/__tests__",
    "build": "tsc",
    "deploy": "esbuild src/index.ts --bundle --platform=node --target=es2020 --minify --outfile=mcap_schema_cli/dist/index.js --banner:js='#!/usr/bin/env node\nimport { createRequire as __createRequire } from \"module\";\nconst require = __createRequire(import.meta.url);'",
    "dev": "tsc && node dist/index.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.25.8",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@foxglove/ros2idl-parser": "^0.3.5",
    "@foxglove/rosmsg": "^5.0.4",
    "@mcap/core": "^2.1.7",
    "@mcap/nodejs": "^1.0.2",
    "@mcap/support": "^1.0.4",
    "commander": "^14.0.0"
  }
}
